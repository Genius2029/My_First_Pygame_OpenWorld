        self.spawned = False

    def spawn(self):
        global boss_spawn_sound
        current_boss_level = hero.score // 10
        if hero.score >= 10 and current_boss_level > self.last_spawned_boss_level and not self.active:
            self.active = True
            self.spawned = True
            self.last_spawned_boss_level = current_boss_level 
            boss_spawn_sound.play()
            show_msg(f"BOSS {current_boss_level} LVL IS SPAWNED!")
            print(f"{RED} BOSS {current_boss_level} LVL IS SPAWNED!")

    def move(self, hero , ult_active):
        if self.active and self.spawned:
            if not ult_active:
                if self.x < hero.x: self.x += self.speed
                if self.x > hero.x: self.x -= self.speed
                if self.y < hero.y: self.y += self.speed
                if self.y > hero.y: self.y -= self.speed
            else:
                pass
    def draw(self, screen , boss_img, offset_x , offset_y):
        if self.active and self.spawned:
            screen.blit(boss_img, (self.x + offset_x, self.y + offset_y))
            pygame.draw.rect(screen, (255, 0, 0), (self.x + offset_x, self.y - 10 + offset_y, (self.hp/self.max_hp)*80, 5))
