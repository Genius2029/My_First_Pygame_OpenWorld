def save_game(score, speed, stamina, high_score, purchased_weapons):
    data = {
        "score": score,
        "speed": speed,
        "stamina": stamina,
        "high_score": high_score,
        "purchased_weapons": purchased_weapons,
        "achievements": list(unlocked_achievements)
    }
    try:
        with open("save.json", "w") as f:
            json.dump(data, f , indent=4)
    except Exception as e:
        print(f"Error saving data: {e}")

def load_game():
    global unlocked_achievements
    global purchased_weapons
    try:
        with open("save.json", "r") as f:
            data = json.load(f)
            
            s = data["score"]
            sp = data["speed"]
            st = data["stamina"]
            h_s = data["high_score"]
            purchased_weapons = data.get("purchased_weapons", [])
            unlocked_achievements = set(data.get("achievements", []))
            
            print(f"success loaded: Score={s}, Speed={sp}, Stamina={st}, h_s={h_s}")
            print(f"Success JSON loaded! Achievements in system: {unlocked_achievements}")
            print(f"Success JSON loaded! Weapons in system: {purchased_weapons}")
            return s, sp, st, h_s
            
    except Exception as e:
        print(f"Data is not finded or nothing in file , starting with base. Error: {e}")
        purchased_weapons = ["pistol"]
        unlocked_achievements = set()
        return 0, 2.5, 100, 0
